# Beacon Caddyfile — TLS reverse proxy. No auth here; backend issues JWT.
{
	local_certs
	admin off
}

:80 {
	redir https://{host}{uri} permanent
}

https://localhost, https://127.0.0.1, https://{$EXTRA_HOSTNAME} {
	tls internal
	encode zstd gzip

	handle /healthz {
		respond "ok" 200
	}

	# Backend API + WebSockets
	@api {
		path /api/* /ws/*
	}
	handle @api {
		reverse_proxy {$BACKEND_UPSTREAM}
	}

	# Static SPA + history-mode fallback
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}

	log {
		output stdout
		format console
	}
}
