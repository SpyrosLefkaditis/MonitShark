# ============================================================
# Beacon — environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- LLM (required) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_replace_me

# --- Auth (required) ---
# Signs JWTs issued by /api/auth/login. Generate with:  openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars

# --- Ports (override the defaults from config/port.yml without editing yaml) ---
# HTTP_PORT=80
# HTTPS_PORT=443

# --- Optional ---
LOG_LEVEL=info
# Extra hostname Caddy should serve in addition to localhost / 127.0.0.1.
# EXTRA_HOSTNAME=admin.example.lan
# Override Caddy's upstream (only if you change networking model):
# BACKEND_UPSTREAM=host.docker.internal:8000
