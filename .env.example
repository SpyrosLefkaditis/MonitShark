# ============================================================
# Beacon — environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- LLM (required) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_replace_me

# --- Web auth (required) ---
# The username for HTTP Basic Auth at the Caddy edge.
ADMIN_USER=admin

# Bcrypt hash of the admin password. Generate with:
#   docker run --rm caddy:2.8-alpine caddy hash-password --plaintext "your-password"
# Then DOUBLE every `$` in the output before pasting here. Docker Compose
# treats a single `$` as variable expansion, so the literal hash chars must
# be `$$`. Example transformation:
#   real hash output:  $2a$14$abcd1234...
#   what you paste:    $$2a$$14$$abcd1234...
ADMIN_PASS_HASH=$$2a$$14$$REPLACE$$WITH$$REAL$$HASH

# --- Backend bearer token (required) ---
# Belt + suspenders auth. Backend rejects requests without this header even if
# Caddy basic_auth somehow passes through. Generate with:
#   openssl rand -hex 32
BACKEND_BEARER_TOKEN=replace_with_64_hex_chars

# --- Optional ---
LOG_LEVEL=info
# Extra hostname Caddy should serve in addition to localhost / 127.0.0.1.
# EXTRA_HOSTNAME=admin.example.lan
# Override Caddy's upstream (only if you change networking model):
# BACKEND_UPSTREAM=host.docker.internal:8000
